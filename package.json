    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
