{
  "name": "anthropic-credit-monitor",
  "version": "0.1.0",
  "description": "Proactive Anthropic API credit and health monitor",
  "type": "module",
  "bin": {
    "anthropic-credit-monitor": "dist/cli.js"
  },
  "scripts": {
    "build": "node_modules/.bin/tsc -p tsconfig.build.json",
    "dev": "node_modules/.bin/tsc -p tsconfig.build.json --watch",
